# Copy to /etc/default/lindo-tours and edit values
NODE_ENV=production
PORT=5023
SQLITE_DB_PATH=/var/lib/lindo-tours/lindotours.db
PRIVATE_STORAGE_PATH=/var/lib/lindo-tours/storage

ADMIN_USERNAME=change-me
ADMIN_PASSWORD=change-me
ADMIN_TOKEN_TTL_MS=28800000

CUSTOMER_AUTH_DEBUG=false
CUSTOMER_AUTH_CODE_TTL_MS=600000
CUSTOMER_SESSION_TTL_MS=604800000
CUSTOMER_PROFILE_ID_PREFIX=CUS
CUSTOMER_PORTAL_TOKEN_TTL_MS=1800000

# Google Identity Services web client ID.
# Add your local and production domains to "Authorized JavaScript origins" in Google Cloud.
# Example origins:
# http://localhost:3000
# https://lindotours.omar-xyz.shop
GOOGLE_CLIENT_ID=
# Optional: if you serve multiple web clients, use a comma-separated list instead of GOOGLE_CLIENT_ID.
# GOOGLE_CLIENT_IDS=

DEMO_MODE=false
CONTACT_EMAIL=lindotours@hotmail.com
WHATSAPP_PHONE=5219981440320
DEMO_PAYPAL_URL=

# Use the live endpoint in production. If you still need sandbox, replace it manually.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_API_BASE=https://api-m.paypal.com
PAYPAL_ACCOUNT_EMAIL=

BANK_TRANSFER_BANK_NAME=
BANK_TRANSFER_BENEFICIARY=
BANK_TRANSFER_CLABE=
BANK_TRANSFER_ACCOUNT=
BANK_TRANSFER_CARD_NUMBER=
BANK_TRANSFER_SWIFT=
BANK_TRANSFER_REFERENCE_PREFIX=LT
BANK_TRANSFER_EXPIRY_HOURS=12
PAYPAL_FEE_PERCENT=5
BANK_TRANSFER_FEE_PERCENT=0

ORDER_PUBLIC_ID_PREFIX=LT
